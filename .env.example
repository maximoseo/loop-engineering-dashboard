# Loop Engineering Dashboard frontend configuration
# Copy to .env.local for local development; configure these in Vercel for Production.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_or_anon_key_here

# Server-side API configuration. Set in Vercel Production, never in frontend code.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=sb_publishable_or_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=replace_with_backend_only_secret_key

# Fail-closed authorization: comma-separated authenticated user emails.
LOOP_OPERATOR_EMAILS=operator@example.com
LOOP_APPROVER_EMAILS=approver@example.com
ORCHESTRATOR_WORKER_TOKEN=replace_with_worker_only_token
# Pin every API worker/cron/script process to exactly one tenant workspace UUID.
LOOP_WORKSPACE_ID=00000000-0000-4000-8000-000000000001
# Hard-clamped by code to 1..3; defaults to 2.
WORKER_BATCH_SIZE=2

# Task delivery remains disabled unless explicitly enabled with a route below.
LOOP_TASK_PUBLIC_ENABLED=false
# Option A: send tasks to a worker/Hermes webhook
LOOP_TASK_WEBHOOK_URL=https://your-worker.example.com/loop-task
LOOP_TASK_WEBHOOK_SECRET=optional_bearer_secret
# Option B: send tasks to Telegram
TELEGRAM_BOT_TOKEN=replace_with_bot_token
TELEGRAM_CHAT_ID=replace_with_chat_id

# Sentry (frontend)
VITE_SENTRY_DSN=replace_with_sentry_dsn
