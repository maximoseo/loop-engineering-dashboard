# Loop Engineering Dashboard frontend configuration
# Copy to .env.local for local development; configure these in Vercel for Production.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_or_anon_key_here

# Optional server-side task intake for the New Loop Task form.
# Set in Vercel Production, not in frontend code.
# GET /api/loop-task returns safe delivery-readiness booleans.
# POST /api/loop-task sends a task when public delivery and a route are configured.
LOOP_TASK_PUBLIC_ENABLED=false
# Option A: send tasks to a worker/Hermes webhook
LOOP_TASK_WEBHOOK_URL=https://your-worker.example.com/loop-task
LOOP_TASK_WEBHOOK_SECRET=optional_bearer_secret
# Option B: send tasks to Telegram
TELEGRAM_BOT_TOKEN=replace_with_bot_token
TELEGRAM_CHAT_ID=replace_with_chat_id
